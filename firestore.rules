/**
 * Ultimate Security Rules for Ronda Planner.
 * Enforces a strict model with a Master Admin bypass for the owner.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check - The most powerful check
    function isMaster() {
      return isSignedIn() && (
        request.auth.uid == 'hKUvl9TWZ8eR4wwjMFsTP49xfG22' ||
        request.auth.token.email == 'tirtopbas@gmail.com'
      );
    }

    function isAdmin() {
      return isMaster() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // GLOBAL MASTER BYPASS (POWER FULL ACCESS)
    // ------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isMaster();
    }

    // ------------------------------------------------------------------------
    // Specific Collection Rules (For non-master users)
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaSchedules/{id} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/scheduleRequests/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaReplacements/{id} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /coordinatorAssignments/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isMaster() || isAdmin();
    }

    // Collection Group Rules
    match /{path=**}/scheduleRequests/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/rondaSchedules/{id} {
        allow read: if true;
    }
  }
}