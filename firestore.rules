/**
 * This ruleset enforces a strict, user-centric security model for the Ronda Planner application,
 * with an overlay for administrative access. Optimized for Master Admin control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check based on hardcoded ID and Email
    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'tirtopbas@gmail.com' ||
        request.auth.uid == 'hKUvl9TWZ8eR4wwjMFsTP49xfG22'
      );
    }

    function isAdmin() {
      return isMaster() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // Collection Group Rules
    // ------------------------------------------------------------------------

    match /{path=**}/scheduleRequests/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/rondaSchedules/{id} {
        allow read: if true;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaSchedules/{id} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/scheduleRequests/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaReplacements/{id} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /coordinatorAssignments/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow Master Admin to bootstrap the roles_admin collection
      allow write: if isMaster() || isAdmin();
    }
  }
}