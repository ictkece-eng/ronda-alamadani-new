/**
 * Ultimate Security Rules for Ronda Planner.
 * Memberikan akses mutlak kepada Master Admin (Boss) melalui UID.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Cek apakah user sudah login
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Jalur Sakti Master Admin (Boss) - Menggunakan UID permanen
    function isMaster() {
      return isSignedIn() && (
        request.auth.uid == 'hKUvl9TWZ8eR4wwjMFsTP49xfG22' || 
        request.auth.token.email == 'tirtopbas@gmail.com'
      );
    }

    // Helper: Cek Admin (Master atau terdaftar di roles_admin)
    function isAdmin() {
      return isMaster() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // Helper: Cek pemilik dokumen
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // GLOBAL MASTER BYPASS (VIP ACCESS FOR BOSS)
    // ------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isMaster();
    }

    // ------------------------------------------------------------------------
    // Aturan Spesifik untuk Pengguna Lain
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isMaster() || isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaSchedules/{id} {
      allow read: if true;
      allow write: if isMaster() || isOwner(userId) || isAdmin();
    }

    match /users/{userId}/scheduleRequests/{id} {
      allow read: if isSignedIn();
      allow write: if isMaster() || isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaReplacements/{id} {
      allow read: if isMaster() || isOwner(userId) || isAdmin();
      allow write: if isMaster() || isOwner(userId) || isAdmin();
    }

    match /coordinatorAssignments/{id} {
      allow read: if true;
      allow write: if isMaster() || isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }

    // Collection Group Rules agar query global tidak error
    match /{path=**}/scheduleRequests/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/rondaSchedules/{id} {
        allow read: if true;
    }
  }
}