/**
 * Ultimate Security Rules for Ronda Planner.
 * Menggunakan Master Admin bypass berbasis UID yang tidak bisa dibantah.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check - Jalur UID adalah yang paling stabil (hKUvl9TWZ8eR4wwjMFsTP49xfG22)
    function isMaster() {
      return isSignedIn() && (
        request.auth.uid == 'hKUvl9TWZ8eR4wwjMFsTP49xfG22' || 
        request.auth.token.email == 'tirtopbas@gmail.com'
      );
    }

    function isAdmin() {
      return isMaster() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // GLOBAL MASTER BYPASS (Akses Mutlak untuk Bos)
    // ------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isMaster();
    }

    // ------------------------------------------------------------------------
    // Aturan Koleksi Spesifik (Untuk Pengguna Lain)
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaSchedules/{id} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/scheduleRequests/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/rondaReplacements/{id} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /coordinatorAssignments/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isMaster() || (isOwner(userId) && request.auth.token.email == 'tirtopbas@gmail.com');
    }

    // Collection Group Rules agar query global tidak error
    match /{path=**}/scheduleRequests/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/rondaSchedules/{id} {
        allow read: if true;
    }
  }
}